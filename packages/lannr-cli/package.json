{
  "name": "lannr-cli",
  "version": "1.1.3",
  "type": "module",
  "description": "Command-line interface for the Lannr local agent runtime.",
  "license": "MIT",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "skills/**"
  ],
  "bin": {
    "lannr": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js"
  },
  "types": "./dist/cli.d.ts",
  "scripts": {
    "start": "node dist/cli.js",
    "build": "tsc -b",
    "postbuild": "chmod +x dist/cli.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "lannr-core": "^0.2.0",
    "lannr-extras": "^0.1.1",
    "commander": "^12.1.0",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  }
}
